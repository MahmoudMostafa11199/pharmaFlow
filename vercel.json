{
  "version": 2,
  "functions": {
    "api/server.js": {
      "includeFiles": "server/db.json"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/server.js" },
    {
      "source": "/((?!assets|views|index).*)",
      "destination": "/api/server.js"
    },
    { "source": "/(.*)", "destination": "/$1" }
  ]
}
